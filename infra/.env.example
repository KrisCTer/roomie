# =================================================
# Roomie — Environment Variables
# =================================================
# Copy this file to .env and fill in actual values:
#   cp .env.example .env
#
# Generate secure passwords with:
#   openssl rand -base64 32
#
# For multi-machine (LAN/Tailscale): change *_HOST
# values to the DB server's IP (e.g. 100.64.0.10).
# For single-machine (localhost): keep defaults.
#
# NEVER commit the .env file!
# =================================================

# ─── Infrastructure Hosts ────────────────────────
# Change to DB server IP for multi-machine setup
MYSQL_HOST=localhost
MYSQL_PORT=3306
MONGO_HOST=localhost
MONGO_PORT=27017
REDIS_HOST=localhost
REDIS_PORT=6379
NEO4J_HOST=localhost
NEO4J_PORT=7687
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=localhost
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
MINIO_HOST=localhost
MINIO_PORT=9000

# ─── Database — MySQL (identity-service) ─────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand
MYSQL_DATABASE=roomie
MYSQL_USER=roomie
MYSQL_PASSWORD=CHANGE_ME_use_openssl_rand

# ─── Database — MongoDB ──────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand
MONGO_DATABASE=roomie

# ─── Database — Neo4j (profile-service) ──────────
NEO4J_AUTH=neo4j/CHANGE_ME_use_openssl_rand

# ─── Cache — Redis ───────────────────────────────
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand

# ─── Search — Elasticsearch ──────────────────────
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=CHANGE_ME_use_openssl_rand

# ─── Storage — MinIO (file-service) ──────────────
MINIO_ROOT_USER=roomie
MINIO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand
MINIO_ENDPOINT=http://${MINIO_HOST:-localhost}:${MINIO_PORT:-9000}
MINIO_BUCKET=roomie-files

# ─── Application Secrets ─────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_use_openssl_rand
JWT_SECRET=CHANGE_ME_must_be_at_least_256_bits_long
JWT_SIGNER_KEY=CHANGE_ME_use_openssl_rand
DIGITAL_SIGNATURE_SECRET=CHANGE_ME_use_openssl_rand

# ─── OAuth2 — Google ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=CHANGE_ME_use_openssl_rand

# ─── OAuth2 — Facebook ───────────────────────────
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=CHANGE_ME_use_openssl_rand

# ─── Google Maps API ─────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── AI — Gemini (ai-service) ────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Email (SMTP) ────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=CHANGE_ME_app_specific_password

# ─── Payment — VNPay ─────────────────────────────
VNPAY_MERCHANT_CODE=your-vnpay-merchant-code
VNPAY_SECRET_KEY=CHANGE_ME_use_openssl_rand

# ─── Payment — MoMo ──────────────────────────────
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=CHANGE_ME_use_openssl_rand
MOMO_SECRET_KEY=CHANGE_ME_use_openssl_rand

# ─── Environment ─────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
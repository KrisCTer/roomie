# App client profile for shared multi-machine development
# Use on machine B/C (application hosts).
# This machine does NOT run DB containers; it only connects to machine A.

# DB host IP or DNS (LAN/Tailscale)
DB_HOST=100.64.0.10

# Shared Infrastructure Endpoints (point to DB host)
MYSQL_HOST=${DB_HOST}
MYSQL_PORT=3306
MONGO_HOST=${DB_HOST}
MONGO_PORT=27017
REDIS_HOST=${DB_HOST}
REDIS_PORT=6379
NEO4J_HOST=${DB_HOST}
NEO4J_PORT=7687
KAFKA_HOST=${DB_HOST}
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=${DB_HOST}
ELASTICSEARCH_HOST=${DB_HOST}
ELASTICSEARCH_PORT=9200

# Database - MySQL
MYSQL_ROOT_PASSWORD=CHANGE_ME_match_db_host
MYSQL_DATABASE=roomie
MYSQL_USER=roomie
MYSQL_PASSWORD=CHANGE_ME_match_db_host

# Database - MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_match_db_host
MONGO_DATABASE=roomie

# Database - Neo4j (format: username/password)
NEO4J_AUTH=neo4j/CHANGE_ME_match_db_host

# Cache - Redis
REDIS_PASSWORD=CHANGE_ME_match_db_host

# Storage - MinIO
MINIO_ROOT_USER=roomie
MINIO_ROOT_PASSWORD=CHANGE_ME_match_db_host

# Application Secrets / Security
ADMIN_JWT_SECRET=CHANGE_ME_use_openssl_rand
JWT_SECRET=CHANGE_ME_must_be_at_least_256_bits_long
JWT_SIGNER_KEY=CHANGE_ME_must_be_at_least_32_bytes_long
DIGITAL_SIGNATURE_SECRET=CHANGE_ME_use_openssl_rand

# External Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=CHANGE_ME_use_openssl_rand
FACEBOOK_CLIENT_SECRET=CHANGE_ME_use_openssl_rand
MAIL_PASSWORD=CHANGE_ME_use_openssl_rand

# Payment Providers
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECRET_KEY=CHANGE_ME_use_openssl_rand
MOMO_SECRET_KEY=CHANGE_ME_use_openssl_rand
MOMO_ACCESS_KEY=CHANGE_ME_use_openssl_rand

# Monitoring
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand
PROMETHEUS_RETENTION_TIME=15d

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

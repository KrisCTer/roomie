# LAN shared mode for multi-machine development
# Copy to infra/.env on the machine running backend services
# and update Tailscale/LAN IP values below.

# Shared Infrastructure Endpoints
MYSQL_HOST=100.64.0.10
MYSQL_PORT=3306
MONGO_HOST=100.64.0.10
MONGO_PORT=27017
REDIS_HOST=100.64.0.10
REDIS_PORT=6379
NEO4J_HOST=100.64.0.10
NEO4J_PORT=7687
KAFKA_HOST=100.64.0.10
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=100.64.0.10
ELASTICSEARCH_HOST=100.64.0.10
ELASTICSEARCH_PORT=9200

# Database - MySQL
MYSQL_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand
MYSQL_DATABASE=roomie
MYSQL_USER=roomie
MYSQL_PASSWORD=CHANGE_ME_use_openssl_rand

# Database - MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand
MONGO_DATABASE=roomie

# Database - Neo4j (format: username/password)
NEO4J_AUTH=neo4j/CHANGE_ME_use_openssl_rand

# Cache - Redis
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand

# Storage - MinIO
MINIO_ROOT_USER=roomie
MINIO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand

# Application Secrets / Security
ADMIN_JWT_SECRET=CHANGE_ME_use_openssl_rand
JWT_SECRET=CHANGE_ME_must_be_at_least_256_bits_long
JWT_SIGNER_KEY=CHANGE_ME_must_be_at_least_32_bytes_long
DIGITAL_SIGNATURE_SECRET=CHANGE_ME_use_openssl_rand

# External Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=CHANGE_ME_use_openssl_rand
FACEBOOK_CLIENT_SECRET=CHANGE_ME_use_openssl_rand
MAIL_PASSWORD=CHANGE_ME_use_openssl_rand

# Payment Providers
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECRET_KEY=CHANGE_ME_use_openssl_rand
MOMO_SECRET_KEY=CHANGE_ME_use_openssl_rand
MOMO_ACCESS_KEY=CHANGE_ME_use_openssl_rand

# Monitoring
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_openssl_rand
PROMETHEUS_RETENTION_TIME=15d

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
